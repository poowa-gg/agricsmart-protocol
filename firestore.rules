rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // -------------------------------------------------------------------------
    // DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // FARMERS
    // -------------------------------------------------------------------------
    match /farmers/{farmerId} {
      function isValidFarmer(data) {
        return data.keys().hasAll(['name', 'phone', 'lga', 'state', 'trustScore', 'verificationStatus'])
          && data.name is string && data.name.size() <= 100
          && data.phone is string && data.phone.size() <= 20
          && data.trustScore is number && data.trustScore >= 0 && data.trustScore <= 100
          && data.verificationStatus in ['pending', 'verified', 'rejected'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidFarmer(incoming());
      allow update: if isSignedIn() && (
        // Action: Agent Verification
        (incoming().diff(existing()).affectedKeys().hasOnly(['verificationStatus', 'agentId', 'trustScore']) && isValidFarmer(incoming())) ||
        // Action: Data Update (Sales/Purchases via system)
        (incoming().diff(existing()).affectedKeys().hasOnly(['trustScore', 'insuranceStatus', 'isCreditworthy']) && isValidFarmer(incoming()))
      );
    }

    // -------------------------------------------------------------------------
    // ACTIVITIES
    // -------------------------------------------------------------------------
    match /activities/{activityId} {
      function isValidActivity(data) {
        return data.keys().hasAll(['farmerId', 'type', 'points', 'date'])
          && data.farmerId is string && data.points is number
          && data.type in ['verification', 'input_purchase', 'harvest_sale', 'insurance', 'milestone'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidActivity(incoming()) && exists(/databases/$(database)/documents/farmers/$(incoming().farmerId));
    }

    // -------------------------------------------------------------------------
    // AGENTS
    // -------------------------------------------------------------------------
    match /agents/{agentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(agentId);
    }
  }
}
